        <!-- Stats classes (lowercase typenames from agent additions) -->

        <View>
            <Name>sdpsystemstats</Name>
            <ViewSelectedBy><TypeName>sdpsystemstats</TypeName></ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader><Label>timestamp</Label></TableColumnHeader>

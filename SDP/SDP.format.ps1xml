                    <TableColumnItem><PropertyName>system_name</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>state</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>system_id</PropertyName></TableColumnItem>

<?xml version="1.0" encoding="utf-8"?>
<!--
    SDP module format definitions.

    Every <View> below references properties that actually exist on the
    SDP API response (or on the typed class wrapper that fronts it),
    sourced from silk-sdp-api-docs/. Default column order is:
      1. id
      2. name (when the resource has one)
      3. ref-resolved *_name properties (attached at runtime by
         Update-SDPRefObjects)
      4. other columns useful for the resource

    To tweak any default view: find the matching <View> and edit the
    <TableHeaders> + <TableColumnItems>. Cells render empty when a
    property is absent (e.g. ref didn't resolve via Update-SDPRefObjects),
    not as an error.
-->
<Configuration>
    <ViewDefinitions>

        <!-- =========================================================
             Class-backed types
             ========================================================= -->

        <View>
            <Name>SDPVolume</Name>
            <ViewSelectedBy><TypeName>SDPVolume</TypeName></ViewSelectedBy>
            <TableControl>
                <TableHeaders>
                    <TableColumnHeader><Label>id</Label><Width>6</Width><Alignment>Right</Alignment></TableColumnHeader>
                    <TableColumnHeader><Label>name</Label></TableColumnHeader>
                    <TableColumnHeader><Label>volume_group_name</Label></TableColumnHeader>
                    <TableColumnHeader><Label>sizeInGB</Label><Width>10</Width><Alignment>Right</Alignment></TableColumnHeader>
                    <TableColumnHeader><Label>creationTime</Label></TableColumnHeader>
                    <TableColumnHeader><Label>scsi_sn</Label></TableColumnHeader>
                </TableHeaders>
                <TableRowEntries><TableRowEntry><TableColumnItems>
                    <TableColumnItem><PropertyName>id</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>name</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>volume_group_name</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>sizeInGB</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>creationTime</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>scsi_sn</PropertyName></TableColumnItem>
                </TableColumnItems></TableRowEntry></TableRowEntries>
            </TableControl>
        </View>

        <View>
            <Name>SDPVolumeGroup</Name>
            <ViewSelectedBy><TypeName>SDPVolumeGroup</TypeName></ViewSelectedBy>

                    <TableColumnHeader><Label>quotaInGB</Label><Width>10</Width><Alignment>Right</Alignment></TableColumnHeader>
                    <TableColumnHeader><Label>volumes_count</Label><Alignment>Right</Alignment></TableColumnHeader>
                    <TableColumnHeader><Label>snapshots_count</Label><Alignment>Right</Alignment></TableColumnHeader>
                    <TableColumnHeader><Label>mapped_hosts_count</Label><Alignment>Right</Alignment></TableColumnHeader>
                    <TableColumnHeader><Label>is_dedup</Label></TableColumnHeader>
                </TableHeaders>
                <TableRowEntries><TableRowEntry><TableColumnItems>
                    <TableColumnItem><PropertyName>id</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>name</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>capacity_state</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>quotaInGB</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>volumes_count</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>snapshots_count</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>mapped_hosts_count</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>is_dedup</PropertyName></TableColumnItem>
                </TableColumnItems></TableRowEntry></TableRowEntries>
            </TableControl>
        </View>


                <TableRowEntries><TableRowEntry><TableColumnItems>
                    <TableColumnItem><PropertyName>id</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>ip_address</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>network_mask</PropertyName></TableColumnItem>
                    <TableColumnItem><PropertyName>net_port_name</PropertyName></TableColumnItem>
                </TableColumnItems></TableRowEntry></TableRowEntries>
            </TableControl>
        </View>

        <View>
            <Name>SDPSystemNetPort</Name>
